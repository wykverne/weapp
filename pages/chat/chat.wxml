<view class="chat-container">
  <view class="chat-header">
    <text>房间号：{{roomId}}</text>
  </view>
  <scroll-view class="chat-list" scroll-y="true">
    <block wx:for="{{messages}}" wx:key="id">
      <view class="chat-item {{item.self ? 'self' : 'other'}}">
        <text class="chat-text">{{item.text}}</text>
        <text class="chat-time">{{item.createdAt}}</text>
      </view>
    </block>
  </scroll-view>
  <view class="chat-input">
    <input class="input" placeholder="输入消息，5秒后自动删除" confirm-type="send" bindconfirm="send" bindinput="onInput" value="{{inputValue}}" />
    <button type="primary" size="mini" bindtap="send">发送</button>
  </view>
</view>