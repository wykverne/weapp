.chat-container { display: flex; flex-direction: column; height: 100vh; }
.chat-header { padding: 20rpx; background: #fff; border-bottom: 1rpx solid #eee; }
.chat-list { flex: 1; padding: 20rpx; background: #f6f7f9; }
.chat-item { max-width: 70%; margin: 12rpx 0; padding: 20rpx; border-radius: 16rpx; position: relative; }
.chat-item.self { align-self: flex-end; background: #d6f5d6; }
.chat-item.other { align-self: flex-start; background: #fff; }
.chat-text { font-size: 30rpx; color: #333; }
.chat-time { font-size: 22rpx; color: #999; margin-top: 10rpx; display: block; }
.chat-input { display: flex; gap: 12rpx; padding: 20rpx; background: #fff; border-top: 1rpx solid #eee; }
.input { flex: 1; padding: 20rpx; background-color: #fff; border-radius: 12rpx; border: 1rpx solid #e5e5e5; }